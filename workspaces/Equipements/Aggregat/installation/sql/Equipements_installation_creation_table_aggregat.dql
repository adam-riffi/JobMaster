-- Création de la table agrégat equipements_aggr_parc_mensuel (Teradata)
CREATE TABLE IF NOT EXISTS £TD_HISTO.equipements_aggr_parc_mensuel (
  periode                  VARCHAR(7)     NOT NULL,
  nb_enregistrements       INTEGER,
  cumul_12m                INTEGER,
  date_calcul              TIMESTAMP
)
PRIMARY INDEX (periode);
