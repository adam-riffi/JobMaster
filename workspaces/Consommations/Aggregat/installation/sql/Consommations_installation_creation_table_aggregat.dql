-- Création de la table agrégat cdr_aggr_journalier_client (Teradata)
CREATE TABLE IF NOT EXISTS £TD_HISTO.cdr_aggr_journalier_client (
  periode                  VARCHAR(7)     NOT NULL,
  nb_enregistrements       INTEGER,
  cumul_12m                INTEGER,
  date_calcul              TIMESTAMP
)
PRIMARY INDEX (periode);
