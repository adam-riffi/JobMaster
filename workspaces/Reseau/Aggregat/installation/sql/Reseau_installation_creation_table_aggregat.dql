-- Création de la table agrégat reseau_aggr_kpi_journalier (Teradata)
CREATE TABLE IF NOT EXISTS £TD_HISTO.reseau_aggr_kpi_journalier (
  periode                  VARCHAR(7)     NOT NULL,
  nb_enregistrements       INTEGER,
  cumul_12m                INTEGER,
  date_calcul              TIMESTAMP
)
PRIMARY INDEX (periode);
