-- Agrégation mensuelle interconnexion_aggr_mensuel_operateur par segment (Teradata)

INSERT INTO £TD_HISTO.interconnexion_aggr_mensuel_operateur (
  periode,
  nb_enregistrements,
  date_calcul
)
SELECT
  TO_CHAR(CURRENT_DATE, 'YYYYMM') AS periode,
  COUNT(*) AS nb_enregistrements,
  CURRENT_TIMESTAMP AS date_calcul
FROM £TD_SOCLE.interconnexion t
WHERE CAST(t.date_maj AS DATE) >= (CURRENT_DATE - EXTRACT(DAY FROM CURRENT_DATE) + 1);
