-- Création de la table agrégat recouvrement_aggr_mensuel_statut (Teradata)
CREATE TABLE IF NOT EXISTS £TD_HISTO.recouvrement_aggr_mensuel_statut (
  periode                  VARCHAR(7)     NOT NULL,
  nb_enregistrements       INTEGER,
  cumul_12m                INTEGER,
  date_calcul              TIMESTAMP
)
PRIMARY INDEX (periode);
